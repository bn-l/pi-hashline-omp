{
  "name": "pi-hashline-omp",
  "version": "0.1.0",
  "description": "Full oh-my-pi hashline editing for pi coding agent — hash-anchored reads, text-DSL edits, tree-sitter block ops, and grep integration",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bn-l/pi-hashline-omp.git"
  },
  "author": "bml",
  "keywords": [
    "pi-package",
    "pi",
    "coding-agent",
    "extension",
    "hashline",
    "oh-my-pi"
  ],
  "license": "MIT",
  "files": [
    "index.ts",
    "src",
    "prompts",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": ["./index.ts"]
  },
  "dependencies": {
    "@oh-my-pi/hashline": "^16.2.5",
    "diff": "^9.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "oxlint": "^1.70.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  }
